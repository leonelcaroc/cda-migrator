  submittedByRole          String?
  sortOrder                Int                      @default(0)
  clientVisible            Boolean                  @default(false)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime
  deletedAt                DateTime?
  ApplicationFindingReport ApplicationFindingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId], map: "AFRI_report_idx")
  @@index([sourceFindingId], map: "AFRI_source_finding_idx")
  @@index([sourceReportItemId], map: "AFRI_source_report_item_idx")
}

