model ApplicationFindingReport {
  id                           String                         @id
  referenceId                  String
  applicationFamily            String
  applicationKind              String
  version                      String
  stageRole                    String?
  submittedBy                  String?
  status                       String                         @default("SUBMITTED")
  isFinal                      Boolean                        @default(false)
  clientVisible                Boolean                        @default(false)
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime
  deletedAt                    DateTime?
  ApplicationFindingReportItem ApplicationFindingReportItem[]

  @@index([referenceId, applicationKind, version, clientVisible], map: "AFR_ref_kind_version_client_idx")
  @@index([referenceId, applicationKind, version, isFinal], map: "AFR_ref_kind_version_final_idx")
  @@index([referenceId, applicationKind, version], map: "AFR_ref_kind_version_idx")
}

model ApplicationFindingReportItem {
  id                       String                   @id
  reportId                 String
  sourceFindingId          String?
  sourceReportItemId       String?
