  parent_id        String?
  created_at       DateTime?           @default(now())
  updated_at       DateTime?           @updatedAt
  deleted_at       DateTime?
  status           String              @default("Question")
  is_answerable    Boolean             @default(false)
  cooperatives     Cooperatives[]
  parent           ValidatorQuestion?  @relation("ValidatorQuestionToParent", fields: [parent_id], references: [id])
  children         ValidatorQuestion[] @relation("ValidatorQuestionToParent")
  region           Regions?            @relation(fields: [region_id], references: [id])
  applicationTypes ApplicationType[]   @relation("ApplicationTypeToValidatorQuestion")
}

