generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/client/auth"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_AUTH")
}

model User {
  id                       String          @id @default(uuid())
  lastname                 String?
  firstname                String?
  middlename               String?
  suffix                   String?
  mobile                   String?
  email                    String          @unique
  gender                   String?
  address                  String?
  id_type                  String?
  id_no                    String?
  password                 String?
  role_name                String?
  verified_at              DateTime?
  created_at               DateTime?       @default(now())
  updated_at               DateTime?       @updatedAt
  deleted_at               DateTime?
  refreshToken             String?         @unique
  oauthIdToken             String?
  oauthSub                 String?         @unique
  status                   UserStatus      @default(PENDING)
  provider                 String?
  migrated                 Int?
  last_successful_login_at DateTime?
  loginSessions            LoginSession[]
  supportTickets           SupportTicket[]
}

model LoginSession {
  id             String    @id @default(uuid())
  userId         String
  otp_hash       String
  otp_expires_at DateTime
  expires_at     DateTime
  attempts       Int       @default(0)
  resend_count   Int       @default(0)
  last_resend_at DateTime?
  remember_me    Boolean   @default(false)
  used_at        DateTime?
  created_at     DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String    @id @default(uuid())
  email      String
  expires_at DateTime?
  created_at DateTime? @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String?
  userId    String?
  adminId   String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Admin {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String?
  firstname       String?
  lastname        String?
  middlename      String?
  suffix          String?
  mobile          String?
  id_type         String?
  id_no           String?
  is_default      Boolean?
  verified_at     DateTime?
  refreshToken    String?         @unique
  roleId          String
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  deleted_at      DateTime?
  department_id   String?
  employee_id     String?         @unique
  status          AccountStatus   @default(ACTIVE)
  regionId        String?
  /// When true, the account is treated as away for assignments; login remains allowed (unlike status INACTIVE).
  away_mode       Boolean         @default(false)
  department      Departments?    @relation(fields: [department_id], references: [id])
  region          Regions?        @relation(fields: [regionId], references: [id])
  role            Role            @relation(fields: [roleId], references: [id])
  assignedTickets SupportTicket[]
}

model Role {
  id          String           @id @default(uuid())
  name        String
  description String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  deleted_at  DateTime?
  subRole     String?
  slug        String?          @unique
  admins      Admin[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String
  slug        String           @unique
  description String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  deleted_at  DateTime?
  groupName   String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String?
  permissionId String
  created_at   DateTime   @default(now())
  actionId     String?
  action       Action?    @relation(fields: [actionId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role?      @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model Regions {
  id              String           @id @default(uuid())
  psgcCode        String
  regDesc         String
  regCode         String           @unique
  label           String?
  created_at      DateTime?        @default(now())
  updated_at      DateTime?        @updatedAt
  deleted_at      DateTime?
  admins          Admin[]
  adminSignatures AdminSignature[]
}

model TypesOfID {
  id         String    @id @default(uuid())
  name       String    @unique
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
}

model Departments {
  id         String    @id @default(uuid())
  name       String    @unique
  slug       String
  acronym    String
  created_at DateTime? @default(now())
  updated_at DateTime? @updatedAt
  deleted_at DateTime?
  admins     Admin[]
}

model Module {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  description String?
  actions     Action[]
}

model Action {
  id       String           @id @default(uuid())
  name     String
  moduleId String
  module   Module           @relation(fields: [moduleId], references: [id])
  roles    RolePermission[]
}

model LandingPageConfig {
  id        String   @id @default(uuid())
  sections  Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id                String                @id @default(uuid())
  ticket_number     String                @unique
  subject           String
  status            SupportTicketStatus   @default(OPEN)
  priority          SupportTicketPriority @default(MEDIUM)
  userId            String?
  assignedToAdminId String?
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  closed_at         DateTime?
  messages          SupportMessage[]
  assignedToAdmin   Admin?                @relation(fields: [assignedToAdminId], references: [id])
  user              User?                 @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([assignedToAdminId])
}

model SupportMessage {
  id          String        @id @default(uuid())
  ticketId    String
  senderId    String
  senderType  String
  message     String
  attachments Json?
  isRead      Boolean       @default(false)
  created_at  DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model AdminSignature {
  id              String    @id @default(uuid())
  fullName        String
  email           String
  role            String?
  signatureFileId String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?
  regionId        String?
  team            String?
  region          Regions?  @relation(fields: [regionId], references: [id])
}

model AccountSuspensionRequest {
  id          String                  @id @default(uuid())
  userId      String
  action      String
  reason      String
  status      SuspensionRequestStatus @default(PENDING)
  requestedBy String
  reviewedBy  String?
  reviewNotes String?
  created_at  DateTime                @default(now())
  updated_at  DateTime                @updatedAt
  reviewed_at DateTime?

  @@index([userId])
  @@index([status])
}

model AccountDeletionLog {
  id         String   @id @default(uuid())
  userId     String
  userEmail  String
  reason     String
  deletedBy  String
  created_at DateTime @default(now())

  @@index([userId])
}

enum UserStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  DENIED    @map("denied")
  SUSPENDED @map("suspended")
}

enum AccountStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  SUSPENDED @map("suspended")
  LOCKED    @map("locked")
  ARCHIVED  @map("archived")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SuspensionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
